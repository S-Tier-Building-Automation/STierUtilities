{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "media",
  "description": "Bundled FFmpeg/ffprobe sidecars for HEIC & MOV conversion",
  "windows": ["main"],
  "permissions": [
    {
      "identifier": "shell:allow-execute",
      "allow": [
        {
          "name": "binaries/ffmpeg",
          "sidecar": true,
          "args": true
        },
        {
          "name": "binaries/ffprobe",
          "sidecar": true,
          "args": true
        }
      ]
    }
  ]
}
