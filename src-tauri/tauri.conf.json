{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "S-Tier Utilities",
  "version": "0.5.3",
  "identifier": "com.stierbuildings.utilities",
  "build": {
    "frontendDist": "../src"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "S-Tier Utilities",
        "width": 960,
        "height": 700,
        "minWidth": 720,
        "minHeight": 520
      }
    ],
    "security": {
      "csp": "default-src 'self' 'unsafe-inline' 'unsafe-eval' ipc: http://ipc.localhost; img-src 'self' asset: http://asset.localhost blob: data:; media-src 'self' asset: http://asset.localhost blob: data:",
      "assetProtocol": {
        "enable": true,
        "scope": [
          "$APPCACHE/**"
        ]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "externalBin": [
      "binaries/ffmpeg",
      "binaries/ffprobe"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "createUpdaterArtifacts": true
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/S-Tier-Building-Automation/STierUtilities/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEFGRDMxQjM1Nzc1MTlCOEIKUldTTG0xRjNOUnZUcjNQcGxJNjhybW9oWVhBY2FWN1ZQM1ZwWlVYLzBHcmhSR3hhUDdHRWJreS8K",
      "windows": {
        "installMode": "passive"
      }
    }
  }
}
